    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst globalState = $getWorkflowStaticData('global');\n\nif (!globalState.seenMeetingDedupe) {\n  globalState.seenMeetingDedupe = {};\n}\n\nconst seenDedupeMap = globalState.seenMeetingDedupe;\nconst nowTimestamp = Date.now();\nconst keepForMs = 7 * 24 * 60 * 60 * 1000;\n\nfor (const dedupeKey of Object.keys(seenDedupeMap)) {\n  if (nowTimestamp - Number(seenDedupeMap[dedupeKey] || 0) > keepForMs) {\n    delete seenDedupeMap[dedupeKey];\n  }\n}\n\nconst output = [];\nfor (const item of items) {\n  const dedupeKey = String(item.json.dedupe_key || '').trim();\n  if (!dedupeKey) {\n    output.push(item);\n    continue;\n  }\n\n  if (seenDedupeMap[dedupeKey]) {\n    continue;\n  }\n\n  seenDedupeMap[dedupeKey] = nowTimestamp;\n  output.push(item);\n}\n\nreturn output.length > 0 ? output : [{ json: { type: 'none' } }];\n"
      },
