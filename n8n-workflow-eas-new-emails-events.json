        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const { type, event: ev } = item.json;\n  if (type !== 'event' && type !== 'event_changed') continue;\n  if (!ev) continue;\n\n  const uid = (ev.uid || ev.server_id || `eas-${Date.now()}-${Math.random().toString(36).substr(2,8)}`)\n    .replace(/[^a-zA-Z0-9@._-]/g, '_');\n\n  function toICalUTC(raw) {\n    if (!raw) return '';\n    if (/^\\d{8}T\\d{6}Z$/.test(raw)) return raw;\n    if (/^\\d{8}T\\d{6}$/.test(raw)) return raw + 'Z';\n    return new Date(raw).toISOString().replace(/[-:]/g, '').replace(/\\.\\d{3}/, '');\n  }\n  function icalEsc(s) {\n    return (s || '').replace(/\\\\/g, '\\\\\\\\').replace(/;/g, '\\\\;').replace(/,/g, '\\\\,').replace(/[\\r\\n]+/g, '\\\\n');\n  }\n\n  const dtstart = toICalUTC(ev.start);\n  const dtend = toICalUTC(ev.end);\n  const now = toICalUTC(new Date().toISOString());\n\n  let ical = 'BEGIN:VCALENDAR\\r\\n';\n  ical += 'VERSION:2.0\\r\\n';\n  ical += 'PRODID:-//EAS MCP//EN\\r\\n';\n  ical += 'BEGIN:VEVENT\\r\\n';\n  ical += `UID:${uid}\\r\\n`;\n  ical += `DTSTAMP:${now}\\r\\n`;\n  ical += `DTSTART:${dtstart}\\r\\n`;\n  ical += `DTEND:${dtend}\\r\\n`;\n  ical += `SUMMARY:${icalEsc(ev.subject)}\\r\\n`;\n  if (ev.location) ical += `LOCATION:${icalEsc(ev.location)}\\r\\n`;\n  if (ev.organizer_email) ical += `ORGANIZER;CN=\"${icalEsc(ev.organizer_name || '')}\":mailto:${ev.organizer_email}\\r\\n`;\n  if (ev.attendees) {\n    for (const a of ev.attendees) ical += `ATTENDEE;CN=\"${icalEsc(a.name || '')}\":mailto:${a.email || ''}\\r\\n`;\n  }\n  if (ev.body) ical += `DESCRIPTION:${icalEsc(ev.body.substring(0, 500))}\\r\\n`;\n  if (ev.all_day === '1') ical += 'X-MICROSOFT-CDO-ALLDAYEVENT:TRUE\\r\\n';\n  ical += 'END:VEVENT\\r\\n';\n  ical += 'END:VCALENDAR\\r\\n';\n\n  results.push({ json: { uid, ical, subject: ev.subject, start: ev.start, op: type } });\n}\n\nreturn results.length > 0 ? results : [{ json: { skip: true } }];\n"
      },
