# Exchange server (both channels talk to the same host)
EXCHANGE_HOST=mail.inplatlabs.ru
EXCHANGE_USER=OFFICE\oleg.pokrovskiy
EXCHANGE_PASSWORD=change-me
EXCHANGE_EMAIL=oleg.pokrovskiy@inplatlabs.ru
EWS_URL=https://mail.inplatlabs.ru/EWS/Exchange.asmx
SSL_VERIFY=false

# EAS-specific
EAS_DEVICE_ID=EAS0LEGCLIENT0001
EAS_PROTOCOL=14.1

# Router: which backend to prefer when both are healthy
# ews: use EWS first, fall back to EAS (recommended when VPN is up)
# eas: use EAS first, fall back to EWS
PREFERRED_BACKEND=ews

# State persistence (cursors, Message-ID LRU, internal SyncKeys)
STATE_DIR=/app/state

# MCP server auth
MCP_API_KEY=change-me-to-a-long-random-string
SERVER_HOST=0.0.0.0
SERVER_PORT=8903
LOG_LEVEL=INFO
PUBLIC_URL=
